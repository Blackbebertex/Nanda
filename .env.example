# Google Gemini (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=3

# Server
PORT=8000
NODE_ENV=development
APP_ENV=development

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# Feature flags
WEALTH_CHAIN_ENABLED=true
MAX_DEEP_CHAINS_PER_DAY=3

# Optional infrastructure
DATABASE_URL=
REDIS_URL=
ADMIN_TOKEN=

# Frontend (set in Render static site or inject via config.js)
# BACKEND_URL=https://your-api.onrender.com
